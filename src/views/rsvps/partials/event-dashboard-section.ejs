<section class="mb-6">
    <h2 class="text-xl font-semibold text-slate-700 mb-3">
        <%= title %>
    </h2>

    <% if (items.length===0) { %>
        <p class="text-slate-400 text-sm py-4">
            <%= emptyMessage %>
        </p>
        <% } else { %>
            <div class="overflow-x-auto rounded-xl border border-slate-200">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50 text-slate-500 uppercase text-xs tracking-wide">
                        <tr>
                            <th class="px-4 py-3 text-left">Title</th>
                            <th class="px-4 py-3 text-left">Date</th>
                            <th class="px-4 py-3 text-left">Category</th>
                            <th class="px-4 py-3 text-left">Attendance</th>
                            <th class="px-4 py-3 text-left">Status</th>
                            <th class="px-4 py-3 text-left">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                        <% items.forEach(function(item) { %>
                            <% const event=item.event || item; const attendeeCount=item.attendeeCount ?? 0; const
                                capacity=event.capacity; const attendanceLabel=capacity !=null ? attendeeCount + " / " +
                                capacity : attendeeCount + " attending" ; const isFull=capacity !=null && attendeeCount>
                                = capacity;
                                %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-4 py-3 font-medium text-slate-800">
                                        <a href="/events/<%= event.id %>" class="hover:underline text-indigo-600">
                                            <%= event.title %>
                                        </a>
                                    </td>
                                    <td class="px-4 py-3 text-slate-600 whitespace-nowrap">
                                        <%= event.startDatetime.toLocaleDateString("en-US", { month: "short" ,
                                            day: "numeric" , year: "numeric" }) %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 text-xs capitalize">
                                            <%= event.category %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-slate-600">
                                        <span class="<%= isFull ? 'text-red-500 font-medium' : '' %>">
                                            <%= attendanceLabel %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <% const statusColors={ published: "bg-green-100 text-green-700" ,
                                            draft: "bg-yellow-100 text-yellow-700" ,
                                            cancelled: "bg-red-100 text-red-600" , }; const
                                            colorClass=statusColors[event.status] || "bg-slate-100 text-slate-600" ; %>
                                            <span
                                                class="inline-block px-2 py-0.5 rounded-full text-xs font-medium capitalize <%= colorClass %>">
                                                <%= event.status %>
                                            </span>
                                    </td>
                                    <td class="px-4 py-3 flex gap-2 flex-wrap">
                                        <% if (showPublish) { %>
                                            <form method="POST" action="/events/<%= event.id %>/publish">
                                                <button type="submit"
                                                    class="text-xs px-3 py-1.5 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 transition-colors">
                                                    Publish
                                                </button>
                                            </form>
                                            <% } %>
                                                <% if (showCancel) { %>
                                                    <form method="POST" action="/events/<%= event.id %>/cancel">
                                                        <button type="submit"
                                                            class="text-xs px-3 py-1.5 rounded-lg border border-red-300 text-red-600 hover:bg-red-50 transition-colors">
                                                            Cancel
                                                        </button>
                                                    </form>
                                                    <% } %>
                                                        <a href="/events/<%= event.id %>/edit"
                                                            class="text-xs px-3 py-1.5 rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-100 transition-colors">
                                                            Edit
                                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                    </tbody>
                </table>
            </div>
            <% } %>
</section>