<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <div class="mb-4">
        <h2 class="text-xl font-semibold text-slate-900 mb-1">
            <%= title %>
        </h2>
    </div>

    <% if (items.length===0) { %>
        <p class="text-slate-500 text-sm">
            <%= emptyMessage %>
        </p>
        <% } else { %>
            <ul class="list-none m-0 p-0 grid gap-3.5">
                <% items.forEach((item)=> { %>
                    <li
                        class="flex items-start justify-between gap-4 p-4 border border-slate-200 rounded-xl bg-slate-50">

                        <div class="flex flex-col gap-1 min-w-0">
                            <strong class="text-slate-900 truncate">
                                <%= item.event.title %>
                            </strong>
                            <p class="text-sm text-slate-500 mb-0">
                                <%= item.event.location %>
                            </p>
                            <p class="text-sm text-slate-500 mb-0">
                                <%= item.event.startDatetime.toLocaleDateString("en-US", { weekday: "short" ,
                                    year: "numeric" , month: "short" , day: "numeric" , hour: "2-digit" ,
                                    minute: "2-digit" }) %>
                            </p>
                            <p class="text-sm text-slate-500 mb-0">
                                Category: <span class="capitalize">
                                    <%= item.event.category %>
                                </span>
                            </p>
                            <% if (typeof item.conflictWarning !== "undefined" && item.conflictWarning) { %>
                                <div class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-medium text-amber-800 flex items-start gap-2 mt-2">
                                    <span class="mt-0.5 shrink-0">⚠️</span>
                                    <span><%= item.conflictWarning %></span>
                                </div>
                            <% } %>
                        </div>

                        <div class="flex flex-col items-end gap-2 shrink-0">
                            <% const statusStyles={ going: "bg-green-600/12 text-green-700" ,
                                waitlisted: "bg-yellow-500/12 text-yellow-700" , cancelled: "bg-red-600/12 text-red-700"
                                , }; const style=statusStyles[item.status] ?? "bg-slate-100 text-slate-600" ; %>
                                <span
                                    class="inline-flex items-center justify-center px-2.5 py-1.5 rounded-full text-sm font-semibold capitalize <%= style %>">
                                    <%= item.status %>
                                </span>

                                <% if (showCancel) { %>
                                    <form method="post" action="/events/<%= item.eventId %>/rsvp" class="m-0">
                                        <button type="submit"
                                            class="px-3.5 py-2 rounded-lg bg-red-700 text-white font-medium cursor-pointer hover:bg-red-800 text-sm">
                                            Cancel RSVP
                                        </button>
                                    </form>
                                    <% } %>
                        </div>

                    </li>
                    <% }) %>
            </ul>
            <% } %>
</section>