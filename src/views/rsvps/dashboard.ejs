<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
    <h1 class="text-3xl font-bold text-slate-900 mb-3">My RSVPs</h1>
    <p class="text-slate-500">
        View and manage all the events you have signed up for.
    </p>
</section>

<% if (pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
        <% } %>

            <% const upcomingList=upcoming ?? []; %>
                <% const pastList=pastCancelled ?? []; %>

                    <section class="mb-6">
                        <%- include("partials/rsvp-section", { title: "Upcoming Events" ,
                            emptyMessage: "You have no upcoming RSVPs." , items: upcomingList, showCancel: true, session
                            }) %>
                    </section>

                    <section class="mb-6">
                        <%- include("partials/rsvp-section", { title: "Past & Cancelled Events" ,
                            emptyMessage: "No past or cancelled RSVPs." , items: pastList, showCancel: false, session })
                            %>
                    </section>