<div id="event-status-controls">
    <% if (event.status === "draft") { %>
      <form
        hx-post="/events/<%= event.id %>/publish"
        hx-target="#event-status-controls"
        hx-swap="outerHTML"
        class="m-0"
      >
        <button
          type="submit"
          class="px-4 py-2 rounded bg-green-600 text-white hover:bg-green-700 cursor-pointer"
        >
          Publish Event
        </button>
      </form>
    <% } else if (event.status === "published") { %>
      <form
        hx-post="/events/<%= event.id %>/cancel"
        hx-target="#event-status-controls"
        hx-swap="outerHTML"
        class="m-0"
      >
        <button
          type="submit"
          class="px-4 py-2 rounded bg-red-600 text-white hover:bg-red-700 cursor-pointer"
        >
          Cancel Event
        </button>
      </form>
    <% } else if (event.status === "cancelled") { %>
      <p class="px-4 py-2 rounded bg-slate-100 text-slate-600 text-sm">
        This event is cancelled.
      </p>
    <% } %>
</div>