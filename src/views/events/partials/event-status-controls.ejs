<% if (typeof includeOobBadge === "undefined" || includeOobBadge) { %>
  <span
    id="event-status-badge"
    hx-swap-oob="true"
    class="inline-flex w-fit items-center px-3 py-1 rounded-full text-sm font-semibold
    <%= event.status === 'published'
      ? 'bg-green-100 text-green-700'
      : event.status === 'cancelled'
        ? 'bg-red-100 text-red-700'
        : 'bg-yellow-100 text-yellow-700'
    %>"
  >
    <%= event.status %>
  </span>
<% } %> 

<div id="event-status-controls"
  x-data="{ visible: false }"
  x-init="$nextTick(() => visible = true)"
>
  <div
    x-show="visible"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
  >
    <% if (event.status === "draft") { %>
      <form
        hx-post="/events/<%= event.id %>/publish"
        hx-target="#event-status-controls"
        hx-swap="outerHTML"
        class="m-0"
      >
        <button
          type="submit"
          class="px-4 py-2 rounded bg-green-600 text-white hover:bg-green-700 cursor-pointer transition-colors"
        >
          Publish Event
        </button>
      </form>
    <% } else if (event.status === "published") { %>
      <form
        hx-post="/events/<%= event.id %>/cancel"
        hx-target="#event-status-controls"
        hx-swap="outerHTML"
        class="m-0"
      >
        <button
          type="submit"
          class="px-4 py-2 rounded bg-red-600 text-white hover:bg-red-700 cursor-pointer transition-colors"
        >
          Cancel Event
        </button>
      </form>
    <% } else if (event.status === "cancelled") { %>
      <p class="px-4 py-2 rounded bg-slate-100 text-slate-600 text-sm">
        This event is cancelled.
      </p>
    <% } %>
  </div>
</div>