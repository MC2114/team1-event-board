<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Discover Events</h1>
  <p class="text-slate-500 mb-4">
    Search published upcoming events by title, description, or location.
  </p>

  <form class="m-0" method="GET" action="/events">
    <label for="searchQuery" class="block text-sm font-semibold text-slate-700 mb-2">Search</label>
    <input
      id="searchQuery"
      name="searchQuery"
      type="search"
      value="<%= searchQuery ?? '' %>"
      placeholder="Try: music, cleanup, amherst..."
      class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white text-slate-900 outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200"
    />
    <button
      type="submit"
      class="mt-3 inline-flex items-center px-4 py-2 rounded-lg bg-blue-600 text-white font-medium no-underline hover:bg-blue-700"
    >
      Search
    </button>
  </form>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section id="event-results" class="space-y-4">
  <%- include("./results", { events }) %>
</section>
