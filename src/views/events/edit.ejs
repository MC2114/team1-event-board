<% if (pageError) { %>
  <%- include('../partials/error', { message: pageError }) %>
<% } %>
<div class="edit-event">
  <h1>Edit Event</h1>

  <form method="POST" action="/events/<%= eventId %>/edit">

    <div class="form-group">
      <label for="title">Title <span aria-hidden="true">*</span></label>
      <input type="text" id="title" name="title" required />
    </div>

    <div class="form-group">
      <label for="description">Description <span aria-hidden="true">*</span></label>
      <textarea id="description" name="description" rows="4" required></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location <span aria-hidden="true">*</span></label>
      <input type="text" id="location" name="location" required />
    </div>

    <div class="form-group">
      <label for="category">Category <span aria-hidden="true">*</span></label>
      <select id="category" name="category" required>
        <option value="">Select a category</option>
        <option value="technology">Technology</option>
        <option value="business">Business</option>
        <option value="music">Music</option>
        <option value="art">Art</option>
        <option value="food">Food</option>
        <option value="health">Health</option>
        <option value="education">Education</option>
        <option value="sports">Sports</option>
        <option value="gaming">Gaming</option>
        <option value="networking">Networking</option>
        <option value="party">Party</option>
        <option value="holiday">Holiday</option>
        <option value="birthday">Birthday</option>
        <option value="graduation">Graduation</option>
        <option value="wedding">Wedding</option>
        <option value="movies and tv">Movies and TV</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="form-group">
      <label for="startDatetime">Start Date & Time <span aria-hidden="true">*</span></label>
      <input type="datetime-local" id="startDatetime" name="startDatetime" required />
    </div>

    <div class="form-group">
      <label for="endDatetime">End Date & Time <span aria-hidden="true">*</span></label>
      <input type="datetime-local" id="endDatetime" name="endDatetime" required />
    </div>

    <div class="form-group">
      <label for="capacity">Capacity <span class="hint">(leave blank for no limit)</span></label>
      <input type="number" id="capacity" name="capacity" min="1" />
    </div>

    <div class="form-actions">
      <button type="submit">Save Changes</button>
      <a href="/events/<%= eventId %>">Cancel</a>
    </div>

  </form>
</div>