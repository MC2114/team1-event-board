<section class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-3xl font-bold text-slate-900">Event Manager</h1>
      
        href="/events"
        class="px-4 py-2 text-sm font-medium text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 no-underline"
      >
        Back to Events
      </a>
    </div>
  
    <p class="text-slate-500 mb-6">
      <% if (session.authenticatedUser.role === "admin") { %>
        Viewing all events across all organizers.
      <% } else { %>
        Viewing your events.
      <% } %>
    </p>

    <% if (pageError) { %>
        <%- include("../partials/error", { message: pageError }) %>
      <% } %>
    
      <% if (events.length === 0) { %>
        <div class="text-center py-16 text-slate-500">
          <p class="text-lg font-medium">No events to manage.</p>
          <p class="text-sm mt-1">
            <a href="/events/new" class="text-blue-600 hover:underline">
              Create your first event
            </a>
          </p>
        </div>
      <% } else { %>
        <div class="grid gap-4">
            <% events.forEach(function(event) { %>
              <%
                const statusColor =
                  event.status === "published" ? "bg-green-100 text-green-700" :
                  event.status === "draft"     ? "bg-yellow-100 text-yellow-700" :
                  event.status === "cancelled" ? "bg-red-100 text-red-700" :
                                                 "bg-slate-100 text-slate-600";
              %>
              <article class="p-5 bg-white border border-slate-200 rounded-xl shadow-sm">
                <div class="flex items-start justify-between gap-3 flex-wrap">
                  <div>
                    <h2 class="text-xl font-semibold text-slate-900"><%= event.title %></h2>
                    <p class="text-slate-500 text-sm mt-0.5">
                      <%= event.location %> &middot;
                      <%= new Date(event.startDatetime).toLocaleDateString("en-US", {
                        weekday: "short",
                        month: "short",
                        day: "numeric",
                        year: "numeric"
                      }) %>
                    </p>
                  </div>
                  <span class="px-2.5 py-1 text-xs font-semibold rounded-full <%= statusColor %>">
                    <%= event.status %>
                  </span>
                </div>
</section>