<section class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-3xl font-bold text-slate-900">Event Manager</h1>
      
        href="/events"
        class="px-4 py-2 text-sm font-medium text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 no-underline"
      >
        Back to Events
      </a>
    </div>
  
    <p class="text-slate-500 mb-6">
      <% if (session.authenticatedUser.role === "admin") { %>
        Viewing all events across all organizers.
      <% } else { %>
        Viewing your events.
      <% } %>
    </p>

    <% if (pageError) { %>
        <%- include("../partials/error", { message: pageError }) %>
      <% } %>
    
      <% if (events.length === 0) { %>
        <div class="text-center py-16 text-slate-500">
          <p class="text-lg font-medium">No events to manage.</p>
          <p class="text-sm mt-1">
            <a href="/events/new" class="text-blue-600 hover:underline">
              Create your first event
            </a>
          </p>
        </div>
      <% } else { %>
</section>