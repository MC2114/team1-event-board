<% if (!events || events.length === 0) { %>
  <div class="text-center py-16 text-slate-500">
    <p class="text-lg font-medium">No events found.</p>
    <p class="text-sm mt-1">Try adjusting your search or filters.</p>
  </div>
<% } else { %>
  <% events.forEach(function(event) { %>
    <a href="/events/<%= event.id %>"
      class="block no-underline text-inherit rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">
      <article
        class="p-5 bg-white border border-slate-200 rounded-xl shadow-sm flex flex-col gap-2 hover:border-slate-300 hover:shadow transition">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="text-xl font-semibold text-slate-900"><%= event.title %></h2>
            <p class="text-xs font-medium text-slate-500 mt-0.5 capitalize">
              Category: <%= event.category %>
            </p>
            <p class="text-slate-500 text-sm mt-0.5">
              <%= event.location %> |
              <%= new Date(event.startDatetime).toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric", year: "numeric" }) %>
            </p>
          </div>
          <span class="shrink-0 px-2.5 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">
            <%= event.status %>
          </span>
        </div>

        <p class="text-slate-600 text-sm"><%= event.description %></p>

        <p class="text-xs text-slate-400 mt-1">
          <% if (event.capacity !== null) { %>
            Capacity: <%= event.capacity %>
          <% } else { %>
            Capacity: No limit
          <% } %>
        </p>
      </article>
    </a>
  <% }) %>
<% } %>
