<% if (!events || events.length === 0) { %>
  <section class="p-6 border border-dashed border-slate-300 rounded-2xl bg-white">
    <h2 class="text-lg font-semibold text-slate-800 mb-1">No matching events</h2>
    <p class="text-slate-500">Try a different search term.</p>
  </section>
<% } %>

<% if (events && events.length > 0) { %>
  <% events.forEach((event) => { %>
    <article class="p-5 border border-slate-200 rounded-2xl bg-white shadow-sm">
      <div class="flex items-start justify-between gap-3 flex-wrap">
        <h2 class="text-xl font-semibold text-slate-900"><%= event.title %></h2>
        <span class="text-xs font-bold uppercase tracking-wide px-2.5 py-1 rounded-full bg-blue-100 text-blue-700">
          <%= event.category %>
        </span>
      </div>
      <p class="text-slate-600 mt-2"><%= event.description %></p>
      <dl class="grid sm:grid-cols-2 gap-2 mt-4 text-sm text-slate-700">
        <div>
          <dt class="font-semibold">Location</dt>
          <dd><%= event.location %></dd>
        </div>
        <div>
          <dt class="font-semibold">Starts</dt>
          <dd><%= event.startDatetime.toLocaleString() %></dd>
        </div>
      </dl>
    </article>
  <% }) %>
<% } %>
