<div class="max-w-3xl mx-auto p-6">
  <div class="bg-white rounded-xl shadow p-6 space-y-5">
    <div class="space-y-1">
      <h1 class="text-3xl font-bold"><%= event.title %></h1>
      <p class="text-sm text-gray-500"><%= event.category %></p>
    </div>

    <p class="text-gray-800"><%= event.description %></p>

    <div class="space-y-2 text-sm text-gray-700">
      <p><strong>Location:</strong> <%= event.location %></p>
      <p><strong>Starts:</strong> <%= event.startDatetime.toLocaleString() %></p>
      <p><strong>Ends:</strong> <%= event.endDatetime.toLocaleString() %></p>
      <p><strong>Status:</strong> <%= event.status %></p>
      <p>
        <strong>Attending:</strong>
        <%= attendeeCount %>
        <% if (event.capacity !== null) { %>
          / <%= event.capacity %>
        <% } else { %>
          / No limit
        <% } %>
      </p>
    </div>

    <div class="pt-4 border-t border-gray-200 space-y-3">
      <p class="text-sm font-medium text-gray-800">Attendance</p>

      <p class="text-sm text-gray-600">
        Current attendance:
        <strong><%= attendeeCount %></strong>
        <% if (event.capacity !== null) { %>
          / <strong><%= event.capacity %></strong>
        <% } else { %>
          / <strong>No limit</strong>
        <% } %>
      </p>

      <% if (typeof rsvpMessage !== "undefined" && rsvpMessage) { %>
        <div class="rounded-md border border-blue-200 bg-blue-50 px-3 py-2 text-sm text-blue-800">
          <%= rsvpMessage %>
        </div>
      <% } %>

      <% if (user.role === "user") { %>
        <% if (!userRSVP || userRSVP.status === "cancelled") { %>
          <p class="text-sm text-gray-600">
            You are not RSVP'd for this event.
          </p>
        <% } else if (userRSVP.status === "going") { %>
          <p class="text-sm text-green-700 font-medium">
            You are currently RSVP'd for this event.
          </p>
        <% } else if (userRSVP.status === "waitlisted") { %>
          <p class="text-sm text-yellow-700 font-medium">
            You are currently on the waitlist for this event.
          </p>
        <% } %>

        <form method="post" action="/events/<%= event.id %>/rsvp">
          <% if (!userRSVP || userRSVP.status === "cancelled") { %>
            <button
              type="submit"
              class="px-4 py-2 rounded bg-green-600 text-white hover:bg-green-700"
            >
              RSVP
            </button>
          <% } else { %>
            <button
              type="submit"
              class="px-4 py-2 rounded bg-red-600 text-white hover:bg-red-700"
            >
              Cancel RSVP
            </button>
          <% } %>
        </form>

        <% if (event.capacity !== null && attendeeCount >= event.capacity) { %>
          <p class="text-xs text-gray-500">
            This event is currently at capacity. New RSVPs may be added to the waitlist.
          </p>
        <% } %>
      <% } %>

      <% if (user.role === "staff" || user.role === "admin") { %>
        <p class="text-sm text-gray-600">
          Staff and admins cannot RSVP to events.
        </p>
      <% } %>
    </div>

    <% if ((user.role === "staff" && user.userId === event.organizerId) || user.role === "admin") { %>
      <div x-data="{ attendeesOpen: false }">
        <div class="flex gap-3 flex-wrap">
          <a
            href="/events/<%= event.id %>/edit"
            class="px-4 py-2 rounded bg-blue-600 text-white"
          >
            Edit Event
          </a>

          <button
            type="button"
            hx-get="/events/<%= event.id %>/attendees"
            hx-target="#attendee-list-panel"
            hx-swap="innerHTML"
            hx-indicator="#attendee-list-loading"
            @click="if (attendeesOpen) { attendeesOpen = false; $event.preventDefault(); } else { attendeesOpen = true; }"
            class="px-4 py-2 rounded bg-slate-700 text-white cursor-pointer"
            x-text="attendeesOpen ? 'Hide Attendees' : 'View Attendees'"
          >
            View Attendees
          </button>

          <% if (event.status === "draft") { %>
            <form method="post" action="/events/<%= event.id %>/publish">
              <button
                type="submit"
                class="px-4 py-2 rounded bg-green-600 text-white hover:bg-green-700"
              >
                Publish Event
              </button>
            </form>
          <% } else if (event.status === "published") { %>
            <form method="post" action="/events/<%= event.id %>/cancel">
              <button
                type="submit"
                class="px-4 py-2 rounded bg-red-600 text-white hover:bg-red-700"
              >
                Cancel Event
              </button>
            </form>
          <% } else if (event.status === "cancelled") { %>
            <p class="px-4 py-2 rounded bg-slate-100 text-slate-600 text-sm">
              This event is cancelled.
            </p>
          <% } %>
        </div>

        <p id="attendee-list-loading" class="htmx-indicator mt-4 text-sm text-slate-500" role="status" aria-live="polite">
          Loading attendees...
        </p>
        <div id="attendee-list-panel" class="mt-4" aria-live="polite" x-show="attendeesOpen"></div>
      </div>
    <% } %>
  </div>
</div>
