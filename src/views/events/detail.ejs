<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <article class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">
    <div class="p-6 sm:p-8 border-b border-slate-200 bg-gradient-to-br from-slate-50 to-white">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="space-y-2">
          <p class="text-sm font-semibold text-blue-600 uppercase tracking-wide">
            <%= event.category %>
          </p>

          <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 leading-tight">
            <%= event.title %>
          </h1>
        </div>

        <span
          id="event-status-badge"
          class="inline-flex w-fit items-center px-3 py-1 rounded-full text-sm font-semibold
          <%= event.status === 'published'
            ? 'bg-green-100 text-green-700'
            : event.status === 'cancelled'
              ? 'bg-red-100 text-red-700'
              : 'bg-yellow-100 text-yellow-700'
          %>"
        >
          <%= event.status %>
        </span>
      </div>
    </div>

    <div class="p-6 sm:p-8 space-y-8">
      <section>
        <h2 class="text-lg font-semibold text-slate-900 mb-2">About this event</h2>
        <p class="text-slate-700 leading-relaxed">
          <%= event.description %>
        </p>
      </section>

      <section class="grid sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl bg-slate-50 border border-slate-200">
          <p class="text-sm font-semibold text-slate-500">Location</p>
          <p class="mt-1 text-slate-900 font-medium"><%= event.location %></p>
        </div>

        <div class="p-4 rounded-xl bg-slate-50 border border-slate-200">
          <p class="text-sm font-semibold text-slate-500">Attending</p>
          <p class="mt-1 text-slate-900 font-medium">
            <%= attendeeCount %>
            <% if (event.capacity !== null) { %>
              / <%= event.capacity %>
            <% } else { %>
              / No limit
            <% } %>
          </p>
        </div>

        <div
          class="p-4 rounded-xl bg-slate-50 border border-slate-200"
          x-data="{
            start: new Date('<%= event.startDatetime.toISOString() %>'),
            relativeTime() {
              const now = new Date();
              const diffMs = this.start - now;
              const diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24));

              if (diffDays === 0) return 'today';
              if (diffDays === 1) return 'tomorrow';
              if (diffDays === -1) return 'yesterday';
              if (diffDays > 1) return `in ${diffDays} days`;
              return `${Math.abs(diffDays)} days ago`;
            }
          }"
        >
          <p class="text-sm font-semibold text-slate-500">Starts</p>
          <p class="mt-1 text-slate-900 font-medium">
            <%= event.startDatetime.toLocaleString() %>
          </p>
          <p class="mt-1 text-sm text-blue-600" x-text="relativeTime()"></p>
        </div>

        <div
          class="p-4 rounded-xl bg-slate-50 border border-slate-200"
          x-data="{
            end: new Date('<%= event.endDatetime.toISOString() %>'),
            relativeTime() {
              const now = new Date();
              const diffMs = this.end - now;
              const diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24));

              if (diffDays === 0) return 'today';
              if (diffDays === 1) return 'tomorrow';
              if (diffDays === -1) return 'yesterday';
              if (diffDays > 1) return `in ${diffDays} days`;
              return `${Math.abs(diffDays)} days ago`;
            }
          }"
        >
          <p class="text-sm font-semibold text-slate-500">Ends</p>
          <p class="mt-1 text-slate-900 font-medium">
            <%= event.endDatetime.toLocaleString() %>
          </p>
          <p class="mt-1 text-sm text-blue-600" x-text="relativeTime()"></p>
        </div>
      </section>

      <section>
        <%- include("partials/rsvp-section", {
          event,
          attendeeCount,
          user,
          userRSVP,
          rsvpMessage,
          overlapWarning
        }) %>
      </section>

      <% if ((user.role === "staff" && user.userId === event.organizerId) || user.role === "admin") { %>
        <section
          x-data="{ attendeesOpen: false }"
          class="pt-6 border-t border-slate-200 space-y-4"
        >
          <div class="flex gap-3 flex-wrap">
            <a
              href="/events/<%= event.id %>/edit"
              class="inline-flex items-center px-4 py-2 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition"
            >
              Edit Event
            </a>

            <button
              type="button"
              hx-get="/events/<%= event.id %>/attendees"
              hx-target="#attendee-list-panel"
              hx-swap="innerHTML"
              hx-indicator="#attendee-list-loading"
              @click="if (attendeesOpen) { attendeesOpen = false; $event.preventDefault(); } else { attendeesOpen = true; }"
              class="inline-flex items-center px-4 py-2 rounded-xl bg-slate-800 text-white font-semibold hover:bg-slate-900 transition cursor-pointer"
              x-text="attendeesOpen ? 'Hide Attendees' : 'View Attendees'"
            >
              View Attendees
            </button>

            <%- include("partials/event-status-controls", {event, includeOobBadge: false}) %>
          </div>

          <p
            id="attendee-list-loading"
            class="htmx-indicator text-sm text-slate-500"
            role="status"
            aria-live="polite"
          >
            Loading attendees...
          </p>

          <div
            id="attendee-list-panel"
            class="mt-4"
            aria-live="polite"
            x-show="attendeesOpen"
            x-transition.opacity.duration.200ms
          ></div>
        </section>
      <% } %>
    </div>
  </article>
</div>